# Bantay - Environment Configuration Example
# Copy this file to .env and fill in the values.
# IMPORTANT: Never commit your real .env file.

# Master Key for Encrypted Secret Storage (~/.bantay/secrets)
# (Automatically generated by 'bantay login')
# BANTAY_MASTER_KEY=...

# Auth0 Configuration (Required for CIBA)
BANTAY_AUTH0_DOMAIN=your-tenant.jp.auth0.com
BANTAY_AUTH0_CLIENT_ID=your_auth0_client_id          # From Auth0 Application
BANTAY_AUTH0_CLIENT_SECRET=your_auth0_client_secret  # From Auth0 Application
BANTAY_AUTH0_USER_ID=github|your_github_numeric_id   # To retrieve Token Vault keys

# LLM Configuration (OpenAI-compatible)
BANTAY_LLM_BASE_URL=https://api.vultrinference.com/v1 # e.g., Vultr, OpenAI, etc.
BANTAY_LLM_API_KEY=your-api-key                        # Required API key
BANTAY_LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct      # e.g., Qwen 2.5 Coder

# ntfy Configuration (Required for push notifications)
BANTAY_NTFY_URL=https://ntfy.sh
BANTAY_NTFY_TOPIC=your-topic
BANTAY_NTFY_USERNAME=your-username
BANTAY_NTFY_PASSWORD=your-password

# Debugging / Overrides
# BANTAY_FORCE=1
BANTAY_AUTH_PORT=3000
BANTAY_REDIRECT_URI=http://localhost:3000/callback
