{
  "name": "@bantay/cli",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "bantay": "./bin/bantay"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist",
    "lint": "eslint src --ext .ts",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.6.1"
  },
  "dependencies": {
    "@auth0/ai-langchain": "5.0.0",
    "@bantay/core": "workspace:*",
    "axios": "^1.6.0",
    "chalk": "^4.1.0",
    "commander": "^11.0.0",
    "dotenv": "^16.6.1"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
